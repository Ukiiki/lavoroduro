---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<!-- SVG filter for rough / aged stamp edges -->
		<svg width="0" height="0" style="position:absolute">
			<filter id="roughen">
				<feTurbulence type="turbulence" baseFrequency="0.04" numOctaves="4" result="noise" />
				<feDisplacementMap in="SourceGraphic" in2="noise" scale="1.5" />
			</filter>
		</svg>

		<main class="landing">
			<h1 class="stamp">Lavoro<br/>Duro</h1>
			<p class="tagline">Hard work. Real results.</p>
			<a href="mailto:chris@ukiiki.com" class="cta">Contact</a>
		</main>
	</body>
</html>
